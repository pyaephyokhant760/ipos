generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model customer {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // (now()) ကို ဖျက်ပေးပါ
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  email     String    @unique
  username  String    @unique
  password  String
  firstName String
  lastName  String
  phone     String    @unique
  dob       DateTime?
  gender    Gender
  image     String?
  role      Role      @default(ATTENDANT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // အုပ်ချုပ်သောဆိုင်များ (Shop model ရှိ admin field နှင့် ချိတ်ဆက်ရန်)
  shops          Shop[]
  
  // Attendant assignments (explicit many-to-many)
  shopAssignments ShopAttendant[]
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  ADMIN
  ATTENDANT
}

model Shop {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  slug       String @unique
  name       String
  location   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  // Relation ပြင်ဆင်ချက်များ
  adminId    String   @db.ObjectId
  admin      User     @relation(fields: [adminId], references: [id]) // references ဟု ပြင်ပါ
  
  // Attendants (explicit many-to-many for MongoDB)
  attendantIds ShopAttendant[]
}

// Explicit junction model for many-to-many relation (required by MongoDB)
model ShopAttendant {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  shopId  String @db.ObjectId
  userId  String @db.ObjectId
  shop    Shop   @relation(fields: [shopId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
  
  @@unique([shopId, userId])
}